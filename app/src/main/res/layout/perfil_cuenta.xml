<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0F172A"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:id="@+id/textoTituloPerfil"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:text="Mi Perfil"
            android:textColor="#FFFFFF"
            android:textSize="24sp"
            android:textStyle="bold" />

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="#1E293B"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_horizontal"
                android:orientation="vertical"
                android:padding="32dp">

                <androidx.cardview.widget.CardView
                    android:layout_width="120dp"
                    android:layout_height="120dp"
                    android:layout_marginBottom="16dp"
                    app:cardBackgroundColor="#0F172A"
                    app:cardCornerRadius="60dp"
                    app:cardElevation="0dp">

                    <ImageView
                        android:id="@+id/imagenPerfilUsuario"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:src="@android:drawable/ic_menu_camera" />
                </androidx.cardview.widget.CardView>

                <TextView
                    android:id="@+id/textoNombreUsuario"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Cargando..."
                    android:textColor="#FFFFFF"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/textoRolUsuario"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="24dp"
                    android:text="Puesto en la banda"
                    android:textColor="#9CA3AF"
                    android:textSize="14sp" />

                <Button
                    android:id="@+id/botonEditarPerfil"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginBottom="12dp"
                    android:backgroundTint="#3B82F6"
                    android:text="Editar Perfil"
                    android:textAllCaps="false"
                    android:textColor="#FFFFFF" />

                <Button
                    android:id="@+id/botonCerrarSesion"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:backgroundTint="#0F172A"
                    android:text="Cerrar Sesión"
                    android:textAllCaps="false"
                    android:textColor="#EF4444" />

                <LinearLayout
                    android:id="@+id/contenedorEdicion"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:text="Modificar mis datos"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold" />

                    <EditText
                        android:id="@+id/editNombre"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:backgroundTint="#3B82F6"
                        android:hint="Nombre"
                        android:textColor="#FFFFFF"
                        android:textColorHint="#9CA3AF" />

                    <EditText
                        android:id="@+id/editApellidos"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:backgroundTint="#3B82F6"
                        android:hint="Apellidos"
                        android:textColor="#FFFFFF"
                        android:textColorHint="#9CA3AF" />

                    <EditText
                        android:id="@+id/editDni"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:backgroundTint="#3B82F6"
                        android:hint="DNI"
                        android:textColor="#FFFFFF"
                        android:textColorHint="#9CA3AF" />

                    <EditText
                        android:id="@+id/editEmail"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:backgroundTint="#3B82F6"
                        android:hint="Email"
                        android:inputType="textEmailAddress"
                        android:textColor="#FFFFFF"
                        android:textColorHint="#9CA3AF" />

                    <EditText
                        android:id="@+id/editTelefono"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:backgroundTint="#3B82F6"
                        android:hint="Teléfono"
                        android:inputType="phone"
                        android:textColor="#FFFFFF"
                        android:textColorHint="#9CA3AF" />

                    <EditText
                        android:id="@+id/editEmergencia"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:backgroundTint="#3B82F6"
                        android:hint="Contacto Emergencia"
                        android:inputType="phone"
                        android:textColor="#FFFFFF"
                        android:textColorHint="#9CA3AF" />

                    <EditText
                        android:id="@+id/editDireccion"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:backgroundTint="#3B82F6"
                        android:hint="Dirección"
                        android:textColor="#FFFFFF"
                        android:textColorHint="#9CA3AF" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:orientation="horizontal">

                        <EditText
                            android:id="@+id/editTallaCamisa"
                            android:layout_width="0dp"
                            android:layout_height="48dp"
                            android:layout_weight="1"
                            android:backgroundTint="#3B82F6"
                            android:hint="Camisa"
                            android:textColor="#FFFFFF"
                            android:textColorHint="#9CA3AF" />

                        <EditText
                            android:id="@+id/editTallaChaqueta"
                            android:layout_width="0dp"
                            android:layout_height="48dp"
                            android:layout_weight="1"
                            android:backgroundTint="#3B82F6"
                            android:hint="Chaqueta"
                            android:textColor="#FFFFFF"
                            android:textColorHint="#9CA3AF" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <EditText
                            android:id="@+id/editTallaPantalon"
                            android:layout_width="0dp"
                            android:layout_height="48dp"
                            android:layout_weight="1"
                            android:backgroundTint="#3B82F6"
                            android:hint="Pantalón"
                            android:textColor="#FFFFFF"
                            android:textColorHint="#9CA3AF" />

                        <EditText
                            android:id="@+id/editTallaGorra"
                            android:layout_width="0dp"
                            android:layout_height="48dp"
                            android:layout_weight="1"
                            android:backgroundTint="#3B82F6"
                            android:hint="Gorra"
                            android:textColor="#FFFFFF"
                            android:textColorHint="#9CA3AF" />
                    </LinearLayout>

                    <Button
                        android:id="@+id/botonGuardarCambios"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:layout_marginTop="16dp"
                        android:backgroundTint="#22C55E"
                        android:text="Actualizar en Base de Datos"
                        android:textAllCaps="false" />
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>
    </LinearLayout>
</ScrollView>